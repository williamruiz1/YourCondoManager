DATABASE_URL=postgres://user:password@host:5432/database

ADMIN_API_KEY=replace-with-admin-api-key
SESSION_SECRET=replace-with-session-secret
AUTH_RESTORE_SECRET=replace-with-auth-restore-secret
PORTAL_OTP_SECRET=replace-with-portal-otp-secret
SESSION_MAX_AGE_MS=604800000
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_CALLBACK_URL_STRICT=false
GOOGLE_CALLBACK_PATH=/api/auth/google/callback

# ── Email provider ─────────────────────────────────────────────────────────────
# Preferred path: Resend (domain-authenticated, SPF/DKIM pass guaranteed).
# Set EMAIL_PROVIDER=resend + RESEND_API_KEY to send as noreply@yourcondomanager.org.
# Fallback: SMTP (only works for the real domain when routed through a
# domain-auth relay such as Resend's SMTP bridge or AWS SES — NOT Gmail SMTP).
# See docs/operations/email-sender-setup.md for DNS records + full setup guide.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address for transactional system emails (both Resend and SMTP paths).
# Must match a domain verified in your provider's dashboard.
EMAIL_FROM=YourCondoManager <noreply@yourcondomanager.org>
EMAIL_FROM_ADDRESS=noreply@yourcondomanager.org
EMAIL_FROM_NAME=YourCondoManager
EMAIL_REPLY_TO=contact@yourcondomanager.org

# SMTP fallback (local dev / Mailpit / Mailtrap — not for production domain sends)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password

EMAIL_TRACKING_ENABLED=false
EMAIL_TRACKING_BASE_URL=https://app.example.com
EMAIL_TRACKING_RETENTION_DAYS=90
EMAIL_TRACKING_SECRET=replace-with-long-random-secret
EMAIL_ALLOWED_REDIRECT_DOMAINS=example.com,app.example.com

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable tracking.
VITE_GOOGLE_ANALYTICS_ID=

# Google Maps JS API key (for map onboarding, building pin editor, community hub map)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Required APIs: Maps JavaScript API, Places API, Street View Static API
# Leave blank to fall back to plain-text inputs (no map UI shown)
VITE_GOOGLE_MAPS_API_KEY=

EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BACKOFF_MS=500
EMAIL_POOL_MAX_CONNECTIONS=5
EMAIL_POOL_MAX_MESSAGES=100
EMAIL_TLS_REQUIRED=false
EMAIL_SMTP_TIMEOUT_MS=15000

# Plaid (bank feed for HOA accounting reconciliation)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET_SANDBOX=replace-with-sandbox-secret
PLAID_SECRET_DEVELOPMENT=replace-with-development-secret
PLAID_SECRET_PRODUCTION=replace-with-production-secret
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=http://localhost:5000/api/plaid/oauth-return
PLAID_WEBHOOK_URL=http://localhost:5000/api/webhooks/plaid

# Stripe Financial Connections (FC) — DROP-IN, READ-ONLY bank feed for
# reconciliation (alternative to Plaid). Same vendor as Stripe Connect dues.
# OFF by default: when OFF, Plaid is used exactly as before. Accepts 1/true/yes/on.
STRIPE_FINANCIAL_CONNECTIONS_ENABLED=0
# FC uses the platform Stripe keys (no separate FC keys):
#   PLATFORM_STRIPE_SECRET_KEY      — sk_test_… for build/validation; sk_live_… once live
#   PLATFORM_STRIPE_PUBLISHABLE_KEY — pk_test_…/pk_live_… (client FC collection flow)
# (Both are normally set as platform secrets, not env vars — see platform-secrets-store.)
# STRIPE_FC_ENV=test                  # test | production (defaults from NODE_ENV)
# STRIPE_FC_WEBHOOK_SECRET=whsec_…    # REQUIRED in production to verify FC webhooks
# STRIPE_FC_WEBHOOK_VERIFICATION=1    # force webhook signature verification off-prod (testing)
