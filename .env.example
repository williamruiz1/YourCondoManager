DATABASE_URL=postgres://user:password@host:5432/database

ADMIN_API_KEY=replace-with-admin-api-key
SESSION_SECRET=replace-with-session-secret
AUTH_RESTORE_SECRET=replace-with-auth-restore-secret
PORTAL_OTP_SECRET=replace-with-portal-otp-secret
SESSION_MAX_AGE_MS=604800000
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_CALLBACK_URL_STRICT=false
GOOGLE_CALLBACK_PATH=/api/auth/google/callback

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=Platform Notifications
EMAIL_REPLY_TO=support@example.com

EMAIL_TRACKING_ENABLED=false
EMAIL_TRACKING_BASE_URL=https://app.example.com
EMAIL_TRACKING_RETENTION_DAYS=90
EMAIL_TRACKING_SECRET=replace-with-long-random-secret
EMAIL_ALLOWED_REDIRECT_DOMAINS=example.com,app.example.com

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable tracking.
VITE_GOOGLE_ANALYTICS_ID=

EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BACKOFF_MS=500
EMAIL_POOL_MAX_CONNECTIONS=5
EMAIL_POOL_MAX_MESSAGES=100
EMAIL_TLS_REQUIRED=false
EMAIL_SMTP_TIMEOUT_MS=15000

# Plaid (bank feed for HOA accounting reconciliation)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET_SANDBOX=replace-with-sandbox-secret
PLAID_SECRET_DEVELOPMENT=replace-with-development-secret
PLAID_SECRET_PRODUCTION=replace-with-production-secret
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=http://localhost:5000/api/plaid/oauth-return
PLAID_WEBHOOK_URL=http://localhost:5000/api/webhooks/plaid
