    "test": "vitest run",
    "test:client": "vitest run --config vitest.config.client.ts",
    "test:server": "vitest run --config vitest.config.server.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:playwright": "playwright test",
    "test:playwright:chromium": "playwright test --project=chromium",
    "test:playwright:install": "playwright install chromium firefox webkit",
    "test:playwright:real": "PLAYWRIGHT_REAL_BACKEND=1 playwright test",
    "test:playwright:test-mode": "PLAYWRIGHT_REAL_BACKEND=1 PLAYWRIGHT_TEST_MODE=1 playwright test",
    "test:playwright:visual": "playwright test --grep @visual --project=chromium",
    "test:playwright:visual:update": "playwright test --grep @visual --project=chromium --update-snapshots",
    "test:payments": "tsx tests/payment-acceptance.ts",
    "verify:mobile": "tsx script/verify-mobile-journeys.ts",
    "verify:owner-portal-multi-unit": "tsx script/verify-owner-portal-multi-unit.ts",
    "verify:elections": "tsx script/verify-elections.ts",
    "verify:vendors": "tsx script/verify-vendors.ts",
    "verify:work-orders": "tsx script/verify-work-orders.ts",
    "verify:seed-integrity": "tsx script/verify-seed-integrity.ts",
    "verify:financial": "tsx script/verify-financial.ts",
    "verify:gl-reconcile": "tsx script/verify-gl-reconcile.ts",
    "verify:gl-amenity": "tsx script/verify-gl-amenity.ts",
