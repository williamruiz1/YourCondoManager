    "benchmark:ingestion": "tsx script/benchmark-ai-ingestion-accuracy.ts",
    "db:push": "drizzle-kit push",
    "db:sync": "tsx server/scripts/sync-db.ts",
    "db:sync:dry": "tsx server/scripts/sync-db.ts --dry-run",
    "migrate": "node scripts/migrate.cjs",
    "migrate:backfill": "node scripts/backfill-migration-journal.cjs",
    "migrate:backfill:dry": "DRY_RUN=1 node scripts/backfill-migration-journal.cjs",
