{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$HOME/.pocketpm/bin:$PWD/.pocketpm/bin:$PATH\" command -v ppm >/dev/null && ppm _hook session-start || true",
            "description": "Inject live PPM state into the Claude Code session context",
            "serverSideEquivalent": "mcp__pocketpm__ppm_bootstrap"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$HOME/.pocketpm/bin:$PWD/.pocketpm/bin:$PATH\" command -v ppm >/dev/null && ppm _hook heartbeat || true",
            "description": "Per-turn heartbeat: surface unsynced edits, open blockers, stale context",
            "serverSideEquivalent": "mcp__pocketpm__ppm_sync freshness scan"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$HOME/.pocketpm/bin:$PWD/.pocketpm/bin:$PATH\" command -v ppm >/dev/null && ppm _hook dirty-increment || true",
            "description": "Increment the local dirty-edit counter in .pocketpm/session.json",
            "serverSideEquivalent": "server-side edits-since-sync counter (Phase C)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$HOME/.pocketpm/bin:$PWD/.pocketpm/bin:$PATH\" command -v ppm >/dev/null && ppm _hook pre-bash || true",
            "description": "Block `git commit*` if PPM sync is stale",
            "serverSideEquivalent": "ppm_sync freshness gate in mcp__pocketpm__ppm_session_end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$HOME/.pocketpm/bin:$PWD/.pocketpm/bin:$PATH\" command -v ppm >/dev/null && ppm _hook session-end || true",
            "description": "Refuse session termination until ppm_session_end has been called",
            "serverSideEquivalent": "mcp__pocketpm__ppm_session_end + orphan-session sweeper"
          }
        ]
      }
    ]
  }
}
